# 丰源工作台 - 环境变量模板
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env

# ===== Flask =====
# Session 加密密钥。生产环境**必须**改成强随机值：
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-32-byte-hex-string

# ===== Moonshot Kimi Vision API =====
# 出货单 AI 图片识别使用。申请地址：https://platform.moonshot.cn/
# 格式：sk-xxxxxxxxxxxxxxxx
MOONSHOT_API_KEY=sk-your-moonshot-api-key

# ===== 运行环境 =====
# development = 调试模式，模板自动重载
# production  = 关闭 debug，使用生产 WSGI
FLASK_ENV=development

# ===== 可选：数据库路径 =====
# 留空则使用默认 worklog.db
# DATABASE_PATH=
